# Copy to .env.local (gitignored). Restart dev server after changes.
# Vite only exposes VITE_* variables to the client — use VITE_SUPABASE_* below.

VITE_GEMINI_API_KEY=
VITE_OPENAI_API_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Documented aliases (set the VITE_* keys above; these are not read by Vite client)
SUPABASE_URL=
SUPABASE_ANON_KEY=
